{
  "toolchains": [
    {
      "toolchain": "bb",
      "from": "scratch",
      "config": {
        "version": "1.12.216",
        "url": "https://github.com/babashka/babashka/releases/download/v1.12.216/babashka-1.12.216-macos-aarch64.tar.gz",
        "sha256": "91499b3f430038f9b40e433215256a6e5392942780dca9984d493d2bcca7055d"
      }
    },
    {
      "toolchain": "go",
      "from": "scratch",
      "config": {
        "version": "1.25.8",
        "url": "https://go.dev/dl/go1.25.8.darwin-arm64.tar.gz",
        "sha256": "c6547959f5dbe8440bf3da972bd65ba900168de5e7ab01464fbdc7ac8375c21c",
        "strip_prefix": "go"
      }
    }
  ],
  "plugins": [
    {"name": "go", "script": "../mu/plugins/go/plugin.bb"}
  ],
  "targets": [
    {
      "target": "//bootstrap:image",
      "toolchain": "shell",
      "sources": [
        "go.mod",
        "go.sum",
        "cmd/bootstrap/*.go",
        "compiler/*.go",
        "compiler/hash/*.go",
        "vm/*.go",
        "vm/dist/*.go",
        "types/*.go",
        "manifest/*.go",
        "gowrap/*.go",
        "pipeline/*.go",
        "version/*.go",
        "lib/*.mag",
        "lib/compiler/*.mag",
        "lib/guide/*.mag"
      ],
      "config": {
        "command": ["sh", "-c", "go run ./cmd/bootstrap/ && cp maggie.image cmd/mag/maggie.image"],
        "outputs": ["maggie.image", "cmd/mag/maggie.image"],
        "impure": true,
        "network": false
      }
    },
    {
      "target": "//cmd/mag",
      "toolchain": "go",
      "sources": [
        "go.mod",
        "go.sum",
        "cmd/mag/*.go",
        "cmd/mag/maggie.image",
        "compiler/*.go",
        "compiler/hash/*.go",
        "vm/*.go",
        "vm/dist/*.go",
        "types/*.go",
        "manifest/*.go",
        "gowrap/*.go",
        "pipeline/*.go",
        "server/*.go",
        "gen/maggie/v1/*.go",
        "gen/maggie/v1/maggiev1connect/*.go",
        "version/*.go"
      ],
      "deps": ["//bootstrap:image"],
      "config": {
        "output": "mag",
        "pkg": "./cmd/mag",
        "cgo": true
      }
    },
    {
      "target": "//doctest",
      "toolchain": "shell",
      "sources": [
        "lib/*.mag",
        "lib/compiler/*.mag",
        "lib/guide/*.mag"
      ],
      "deps": ["//cmd/mag"],
      "config": {
        "command": ["./mag", "doctest"],
        "impure": true
      }
    },
    {
      "target": "//test",
      "toolchain": "shell",
      "sources": [
        "go.mod",
        "go.sum",
        "**/*.go",
        "lib/*.mag",
        "lib/compiler/*.mag",
        "lib/guide/*.mag"
      ],
      "deps": ["//bootstrap:image"],
      "config": {
        "command": ["go", "test", "./..."],
        "impure": true,
        "network": false
      }
    },
    {
      "target": "//lint/go-vet",
      "toolchain": "shell",
      "sources": ["**/*.go"],
      "config": {
        "command": ["go", "vet", "./..."],
        "impure": true
      }
    },
    {
      "target": "//lint",
      "toolchain": "shell",
      "sources": [],
      "deps": ["//lint/go-vet"],
      "config": {
        "command": ["true"],
        "impure": false
      }
    },
    {
      "target": "//all",
      "toolchain": "shell",
      "sources": [],
      "deps": ["//cmd/mag", "//test", "//doctest", "//lint"],
      "config": {
        "command": ["true"],
        "impure": false
      }
    }
  ]
}
