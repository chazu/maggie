"""
Core structural protocols for the Maggie standard library.

Protocols define structural types — a set of message signatures that a class
must respond to. They are checked by `mag typecheck` and have zero runtime cost.
"""

"""
Any object that has a countable size.
"""
Sizeable protocol
  size ^<Integer>.
  isEmpty ^<Boolean>.
  notEmpty ^<Boolean>.

"""
Any object whose elements can be accessed by integer index.
"""
Indexable protocol
  includes: Sizeable.
  at: <Integer> ^<Object>.

"""
Any object that supports ordering comparisons. (Named Ordered so the
Comparable TRAIT — a different construct — keeps sole claim to its name.)
"""
Ordered protocol
  < <Object> ^<Boolean>.
  > <Object> ^<Boolean>.
  <= <Object> ^<Boolean>.
  >= <Object> ^<Boolean>.
  = <Object> ^<Boolean>.
